# Copy to backend/.env and fill in your keys

# AI Provider — choose one: anthropic | openai | ollama
AI_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Also used for embeddings when AI_PROVIDER=anthropic
OPENAI_API_KEY=

# Ollama (local models) — must have Ollama running
OLLAMA_BASE_URL=http://localhost:11434
